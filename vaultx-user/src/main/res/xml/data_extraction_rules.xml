<?xml version="1.0" encoding="utf-8"?>
<!-- Prevents device cloud backup of the vault database -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="vaultx.db" />
        <exclude domain="database" path="vaultx.db-shm" />
        <exclude domain="database" path="vaultx.db-wal" />
        <exclude domain="sharedpref" path="vaultx_secure_prefs.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="vaultx.db" />
        <exclude domain="sharedpref" path="vaultx_secure_prefs.xml" />
    </device-transfer>
</data-extraction-rules>
